# Godot 4+ specific ignores
.godot/

# Godot 3 legacy import cache (Godot 4 uses *.import sidecars next to assets instead)
.import/
export.cfg
export_presets.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# --- Non-Godot tooling (level planner, etc.) ---
# Godot should not import these — also place .gdignore in tools/ (see tools/.gdignore).
tools/**/node_modules/
tools/**/dist/
tools/**/*.import

# Claude Code local files
.claude/
